<!--
  Liquid aurora background using WebGL shader.
  Renders metaball-like blobs with smooth color blending.
  Falls back to static CSS gradient if WebGL unavailable.
-->
<canvas id="aurora-canvas"></canvas>

<style>
  #aurora-canvas {
    position: fixed;
    inset: 0;
    width: 100%;
    height: 100%;
    z-index: 0;
    pointer-events: none;
  }
</style>

<script>
  const canvas = document.getElementById('aurora-canvas') as HTMLCanvasElement;
  const gl = canvas.getContext('webgl', { alpha: true, antialias: false, premultipliedAlpha: true });

  if (!gl) {
    // Fallback: hide canvas, CSS gradient will show
    canvas.style.display = 'none';
  } else {
    // Vertex shader — fullscreen quad
    const vsSource = `
      attribute vec2 a_pos;
      void main() {
        gl_Position = vec4(a_pos, 0.0, 1.0);
      }
    `;

    // Fragment shader — liquid metaballs with color blending
    const fsSource = `
      precision mediump float;
      uniform vec2 u_resolution;
      uniform float u_time;
      uniform vec2 u_mouse;
      uniform float u_dark; // 1.0 = dark mode, 0.0 = light mode

      // Blob: position, radius, color
      vec3 palette(float t, float dark) {
        // Purple-blue-pink palette
        vec3 a = mix(vec3(0.45, 0.35, 0.65), vec3(0.25, 0.15, 0.45), dark);
        vec3 b = mix(vec3(0.25, 0.20, 0.35), vec3(0.20, 0.15, 0.30), dark);
        vec3 c = vec3(1.0, 1.0, 1.0);
        vec3 d = vec3(0.00, 0.15, 0.55);
        return a + b * cos(6.28318 * (c * t + d));
      }

      float metaball(vec2 p, vec2 center, float radius) {
        float d = length(p - center);
        return radius * radius / (d * d + 0.001);
      }

      void main() {
        vec2 uv = gl_FragCoord.xy / u_resolution;
        vec2 aspect = vec2(u_resolution.x / u_resolution.y, 1.0);
        vec2 p = uv * aspect;

        float t = u_time * 0.08;

        // Mouse influence (normalized)
        vec2 mouse = u_mouse * aspect;

        // 7 blobs with different orbits, speeds, and colors
        vec2 b1 = vec2(0.3 + sin(t * 0.7) * 0.25, 0.7 + cos(t * 0.5) * 0.2) * aspect;
        vec2 b2 = vec2(0.7 + cos(t * 0.6) * 0.2, 0.3 + sin(t * 0.8) * 0.25) * aspect;
        vec2 b3 = vec2(0.5 + sin(t * 0.9 + 2.0) * 0.3, 0.5 + cos(t * 0.4 + 1.0) * 0.3) * aspect;
        vec2 b4 = vec2(0.2 + cos(t * 0.5 + 3.0) * 0.2, 0.4 + sin(t * 0.7 + 2.0) * 0.25) * aspect;
        vec2 b5 = vec2(0.8 + sin(t * 0.4 + 1.5) * 0.15, 0.6 + cos(t * 0.6 + 3.0) * 0.2) * aspect;
        vec2 b6 = vec2(0.4 + cos(t * 0.8 + 4.0) * 0.25, 0.2 + sin(t * 0.5 + 2.5) * 0.15) * aspect;
        vec2 b7 = vec2(0.6 + sin(t * 0.3 + 0.5) * 0.2, 0.8 + cos(t * 0.9 + 1.5) * 0.15) * aspect;

        // Mouse attracts nearest blob slightly
        b1 += (mouse - b1) * 0.08;
        b3 += (mouse - b3) * 0.05;

        // Compute metaball field
        float field = 0.0;
        field += metaball(p, b1, 0.22);  // deep purple
        field += metaball(p, b2, 0.18);  // indigo
        field += metaball(p, b3, 0.16);  // magenta
        field += metaball(p, b4, 0.14);  // cyan-blue
        field += metaball(p, b5, 0.15);  // violet
        field += metaball(p, b6, 0.12);  // pink
        field += metaball(p, b7, 0.13);  // teal

        // Color based on field strength and position
        float colorT = field * 0.3 + uv.x * 0.2 + uv.y * 0.1 + t * 0.1;

        // Different color per blob region
        vec3 col1 = vec3(0.47, 0.24, 0.94);  // deep purple
        vec3 col2 = vec3(0.27, 0.16, 0.86);  // indigo
        vec3 col3 = vec3(0.90, 0.31, 0.78);  // magenta
        vec3 col4 = vec3(0.24, 0.55, 1.00);  // blue
        vec3 col5 = vec3(0.71, 0.39, 1.00);  // violet
        vec3 col6 = vec3(1.00, 0.39, 0.55);  // pink
        vec3 col7 = vec3(0.39, 0.86, 1.00);  // teal

        // Weight colors by each blob's contribution
        float total = 0.001;
        vec3 color = vec3(0.0);
        float w1 = metaball(p, b1, 0.22); color += col1 * w1; total += w1;
        float w2 = metaball(p, b2, 0.18); color += col2 * w2; total += w2;
        float w3 = metaball(p, b3, 0.16); color += col3 * w3; total += w3;
        float w4 = metaball(p, b4, 0.14); color += col4 * w4; total += w4;
        float w5 = metaball(p, b5, 0.15); color += col5 * w5; total += w5;
        float w6 = metaball(p, b6, 0.12); color += col6 * w6; total += w6;
        float w7 = metaball(p, b7, 0.13); color += col7 * w7; total += w7;
        color /= total;

        // Smooth threshold for liquid look
        float alpha = smoothstep(0.4, 1.2, field);

        // Subtle ambient — don't overpower content
        float intensity = mix(0.2, 0.3, u_dark);
        alpha *= intensity;

        // Light mode: slightly more saturated
        color = mix(color * 1.2, color, u_dark);

        gl_FragColor = vec4(color * alpha, alpha);
      }
    `;

    function createShader(type: number, source: string): WebGLShader | null {
      const shader = gl!.createShader(type);
      if (!shader) return null;
      gl!.shaderSource(shader, source);
      gl!.compileShader(shader);
      if (!gl!.getShaderParameter(shader, gl!.COMPILE_STATUS)) {
        console.error('Shader error:', gl!.getShaderInfoLog(shader));
        gl!.deleteShader(shader);
        return null;
      }
      return shader;
    }

    const vs = createShader(gl.VERTEX_SHADER, vsSource);
    const fs = createShader(gl.FRAGMENT_SHADER, fsSource);
    if (!vs || !fs) { canvas.style.display = 'none'; }
    else {
      const program = gl.createProgram()!;
      gl.attachShader(program, vs);
      gl.attachShader(program, fs);
      gl.linkProgram(program);

      if (!gl.getProgramParameter(program, gl.LINK_STATUS)) {
        console.error('Program error:', gl.getProgramInfoLog(program));
        canvas.style.display = 'none';
      } else {
        gl.useProgram(program);

        // Fullscreen quad
        const buf = gl.createBuffer();
        gl.bindBuffer(gl.ARRAY_BUFFER, buf);
        gl.bufferData(gl.ARRAY_BUFFER, new Float32Array([-1,-1, 1,-1, -1,1, 1,1]), gl.STATIC_DRAW);
        const aPos = gl.getAttribLocation(program, 'a_pos');
        gl.enableVertexAttribArray(aPos);
        gl.vertexAttribPointer(aPos, 2, gl.FLOAT, false, 0, 0);

        // Uniforms
        const uRes = gl.getUniformLocation(program, 'u_resolution');
        const uTime = gl.getUniformLocation(program, 'u_time');
        const uMouse = gl.getUniformLocation(program, 'u_mouse');
        const uDark = gl.getUniformLocation(program, 'u_dark');

        let mouseX = 0.5, mouseY = 0.5;
        document.addEventListener('mousemove', (e) => {
          mouseX = e.clientX / window.innerWidth;
          mouseY = 1.0 - e.clientY / window.innerHeight;
        });
        document.addEventListener('touchmove', (e) => {
          const t = e.touches[0];
          mouseX = t.clientX / window.innerWidth;
          mouseY = 1.0 - t.clientY / window.innerHeight;
        }, { passive: true });

        function resize() {
          const dpr = Math.min(window.devicePixelRatio, 2);
          canvas.width = window.innerWidth * dpr;
          canvas.height = window.innerHeight * dpr;
          canvas.style.width = '100%';
          canvas.style.height = '100%';
          gl!.viewport(0, 0, canvas.width, canvas.height);
        }
        window.addEventListener('resize', resize);
        resize();

        // Enable blending for alpha
        gl.enable(gl.BLEND);
        gl.blendFunc(gl.SRC_ALPHA, gl.ONE_MINUS_SRC_ALPHA);

        function render(time: number) {
          const isDark = !document.documentElement.classList.contains('light');
          gl!.uniform2f(uRes, canvas.width, canvas.height);
          gl!.uniform1f(uTime, time * 0.001);
          gl!.uniform2f(uMouse, mouseX, mouseY);
          gl!.uniform1f(uDark, isDark ? 1.0 : 0.0);

          gl!.clearColor(0, 0, 0, 0);
          gl!.clear(gl!.COLOR_BUFFER_BIT);
          gl!.drawArrays(gl!.TRIANGLE_STRIP, 0, 4);
          requestAnimationFrame(render);
        }
        requestAnimationFrame(render);
      }
    }
  }
</script>
